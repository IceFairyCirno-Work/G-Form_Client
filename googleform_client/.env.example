# Google OAuth Configuration
GOOGLE_SERVER_CLIENT_ID=your-server-client-id.apps.googleusercontent.com

# Google OAuth Scopes
GOOGLE_SCOPE_FORMS_BODY=https://www.googleapis.com/auth/forms.body
GOOGLE_SCOPE_FORMS_BODY_READONLY=https://www.googleapis.com/auth/forms.body.readonly
GOOGLE_SCOPE_FORMS=https://www.googleapis.com/auth/forms
GOOGLE_SCOPE_DRIVE=https://www.googleapis.com/auth/drive
GOOGLE_SCOPE_DRIVE_FILE=https://www.googleapis.com/auth/drive.file
GOOGLE_SCOPE_DRIVE_READONLY=https://www.googleapis.com/auth/drive.readonly
GOOGLE_SCOPE_SCRIPT_PROJECTS=https://www.googleapis.com/auth/script.projects
GOOGLE_SCOPE_SPREADSHEETS=https://www.googleapis.com/auth/spreadsheets

# Google Apps Script Configuration
GOOGLE_APPS_SCRIPT_ID=your-apps-script-deployment-id

# Google API Endpoints
GOOGLE_FORMS_API_URL=https://forms.googleapis.com/v1/forms
GOOGLE_DRIVE_API_URL=https://www.googleapis.com/drive/v3/files
GOOGLE_DRIVE_UPLOAD_URL=https://www.googleapis.com/upload/drive/v3/files
GOOGLE_SHEETS_API_URL=https://sheets.googleapis.com/v4/spreadsheets
GOOGLE_SCRIPT_API_URL=https://script.googleapis.com/v1/scripts
